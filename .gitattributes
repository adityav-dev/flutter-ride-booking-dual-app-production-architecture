# Force Dart detection
*.dart linguist-language=Dart

# Ignore non-Dart files completely
*.cpp linguist-vendored
*.cxx linguist-vendored
*.h linguist-vendored
*.hpp linguist-vendored
*.swift linguist-vendored
CMakeLists.txt linguist-vendored
*.html linguist-vendored
*.kt linguist-vendored
*.java linguist-vendored
*.gradle linguist-vendored

# Optional: ignore entire folders with legacy C++/other files
cpp/** linguist-vendored
legacy/** linguist-vendored